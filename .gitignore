# ============================================================
# .gitignore
# ============================================================
# Files and folders listed here are NEVER tracked by Git.
# This protects secrets, generated files, and OS clutter.
# ============================================================

# ============================================================
# SECRETS & ENVIRONMENT VARIABLES
# ============================================================
# NEVER commit your API keys or database credentials!
.env
.env.local
.env.production
*.env

# ============================================================
# PYTHON
# ============================================================
# Compiled bytecode files (auto-generated, not needed in repo)
__pycache__/
*.py[cod]
*$py.class
*.pyc
*.pyo
*.pyd

# Python virtual environments
venv/
env/
.venv/
.env/
ENV/
env.bak/
venv.bak/

# Python distribution / packaging
*.egg
*.egg-info/
dist/
build/
wheels/
.eggs/
MANIFEST

# Python unit test / coverage reports
.pytest_cache/
.coverage
.coverage.*
htmlcov/
coverage.xml
*.cover
nosetests.xml
pytest.xml

# ============================================================
# DATABASE
# ============================================================
# SQLite database files (auto-created on first run)
*.db
*.sqlite
*.sqlite3
project_manager.db

# ============================================================
# STREAMLIT
# ============================================================
# Streamlit local config and cache
.streamlit/secrets.toml

# ============================================================
# EXPORTS (Generated Files)
# ============================================================
# CSV and Markdown files generated by the export service
exports/
*.csv
*.md
# But keep the README!
!README.md

# ============================================================
# OPERATING SYSTEM FILES
# ============================================================
# macOS
.DS_Store
.AppleDouble
.LSOverride
._*
.Spotlight-V100
.Trashes

# Windows
Thumbs.db
Thumbs.db:encryptable
ehthumbs.db
Desktop.ini
$RECYCLE.BIN/
*.lnk

# Linux
*~

# ============================================================
# IDE & EDITORS
# ============================================================
# VS Code
.vscode/
*.code-workspace

# PyCharm / JetBrains
.idea/
*.iml
*.iws

# Jupyter Notebooks checkpoints
.ipynb_checkpoints/
*.ipynb

# Spyder
.spyderproject.cfg
.spyproject/

# Rope
.ropeproject/

# ============================================================
# LOGS
# ============================================================
*.log
logs/
